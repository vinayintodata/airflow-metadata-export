# Copy to ".env" and adjust. Docker Compose loads ".env" automatically.
# (The real ".env" is gitignored — do not commit secrets.)

AIRFLOW_UID=50000

# Host port for the Airflow web UI / API (default 8085 avoids clashing with another Airflow on 8080)
AIRFLOW_HOST_WEB_PORT=8085

# Required by Airflow for encrypting connections/variables. Generate a new one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_WITH_A_FERNET_KEY
